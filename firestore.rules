rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // ヘルパー関数
    // =============================================
    function isAuth() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function isStudent() {
      return isAuth() && userDoc().role == 'student';
    }
    function isTeacher() {
      return isAuth() && userDoc().role == 'teacher';
    }
    function isAdmin() {
      return isAuth() && userDoc().role == 'admin';
    }
    function isTeacherOrAdmin() {
      return isTeacher() || isAdmin();
    }

    // =============================================
    // users コレクション
    // 自分のドキュメントのみ読み書き可能
    // 管理者はすべて読み取り可能
    // =============================================
    match /users/{userId} {
      allow read:  if isAuth() && (uid() == userId || isAdmin());
      allow create: if isAuth() && uid() == userId;
      allow update: if isAuth() && uid() == userId;
      allow delete: if isAdmin();
    }

    // =============================================
    // cases コレクション（公欠申請）
    // =============================================
    match /cases/{caseId} {
      // 読み取り：ログイン済みなら誰でも可
      // （管理者・先生は自分宛のもの、生徒は自分のものだけを実際に使う）
      allow read: if isAuth();

      // 作成：ログイン済み生徒のみ、自分のIDで申請
      allow create: if isAuth()
        && request.resource.data.studentId == uid()
        && request.resource.data.status == 'pending_supervisor';

      // 更新：ログイン済みユーザーが可（先生・管理者が承認処理）
      allow update: if isAuth();

      // 削除：管理者のみ
      allow delete: if isAdmin();
    }

    // =============================================
    // 手帳コンテンツ（既存）
    // 読み取り：全員、書き込み：管理者のみ
    // =============================================
    match /rules/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /special/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /council-charter/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /council-rules/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /events/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /curriculum/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /history/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /principals/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /songs/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /content/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =============================================
    // お問い合わせ（既存）
    // =============================================
    match /inquiries/{doc} {
      allow read:   if isAdmin();
      allow create: if true;   // 未ログインでも送信可能
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =============================================
    // その他のドキュメント：デフォルト拒否
    // =============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
